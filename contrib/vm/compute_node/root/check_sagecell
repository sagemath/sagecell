#!/bin/sh

systemctl --quiet is-active sagecell
if [ $? -ne 0 ]
then
    echo "`date` Service is not active, skipping check"
    exit 0
fi

/home/{server}/sagecell/contrib/sagecell-client/sagecell-service.py $1
if [ $? -ne 0 ]
then
    echo "===== $(date) pre-restart stats ====="
    # CPU load vs cores
    cores=$(nproc)
    load=$(cut -d' ' -f1-3 /proc/loadavg)
    echo "CPU load: $load (cores: $cores)"
    # Memory
    free -h | awk '/Mem:/ {print "RAM: used " $3 " / total " $2 " (avail " $7 ")"}'
    free -h | awk '/Swap:/ {print "Swap: used " $3 " / total " $2}'
    # Disk IO (requires sysstat: iostat)
    if command -v iostat >/dev/null 2>&1; then
        iostat -dx 1 1 | awk '
            $1 == "Device" {devices=1; next}
            !devices {next}
            $1 ~ /^(loop[0-9]*|ram[0-9]*|sr[0-9]*)$/ {next}
            NF >= 23 {
                printf "Disk %s: util=%s%% aqu-sz=%s r_await=%sms w_await=%sms\n",
                       $1, $23, $22, $6, $12
       }'
    fi
    echo "====================================="
    systemctl restart sagecell
    echo "`date` Restarted."
    echo "************"
    exit 1
fi
